# ── Database ─────────────────────────────────────────────────────────────────
# Pooler URL used at runtime (Neon: add -pooler to hostname)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-frontend.vercel.app

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use long random strings (e.g. openssl rand -base64 64)
JWT_SECRET=change_me_access_token_secret
JWT_REFRESH_SECRET=change_me_refresh_token_secret
