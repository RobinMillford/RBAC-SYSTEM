# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Environment & credentials (NEVER commit these) ───────────────────────────
.env
.env.*
!.env.example        # keep the example template

# ── Next.js build output ──────────────────────────────────────────────────────
/.next/
/out/

# ── Production build ──────────────────────────────────────────────────────────
/build

# ── Testing / coverage ────────────────────────────────────────────────────────
/coverage

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
